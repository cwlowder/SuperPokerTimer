################################################################################
# Poker Tournament Timer — Production Configuration
#
# Copy this file to .env and edit the values below.
# docker compose -f docker-compose.prod.yml up -d
################################################################################

# --- Image version ---
# Pin to a specific release tag (e.g. v1.0.0) or leave as "latest".
IMAGE_TAG=latest

# --- Networking ---
# Port the app binds on the host.
PORT=8000

# --- CORS ---
# Comma-separated origins, or leave empty to restrict to same-origin only.
# Usually not needed since the app serves everything on one origin.
CORS_ALLOW_ORIGINS=
